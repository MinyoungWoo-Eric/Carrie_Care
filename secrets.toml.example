# ─────────────────────────────────────────────────────────────
# 이 파일을 복사해서 같은 폴더에 secrets.toml 로 저장하세요. (로컬 실행용)
# Streamlit Community Cloud에 배포할 때는 이 파일 내용을
# 앱 설정(Settings → Secrets) 화면에 붙여넣으면 됩니다.
#
# ⚠️ secrets.toml 은 절대 GitHub에 올리면 안 됩니다! (.gitignore에 이미 포함)
# ─────────────────────────────────────────────────────────────

# Google Cloud에서 발급받은 서비스 계정 키(JSON)의 내용을 그대로 옮겨 적기
[gcp_service_account]
type = "service_account"
project_id = "your-project-id"
private_key_id = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
private_key = "-----BEGIN PRIVATE KEY-----\n...여러 줄의 키...\n-----END PRIVATE KEY-----\n"
client_email = "carrie-care@your-project-id.iam.gserviceaccount.com"
client_id = "123456789012345678901"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/carrie-care%40your-project-id.iam.gserviceaccount.com"

# 사용할 스프레드시트 지정 — 아래 셋 중 하나만 채우면 됩니다.
# (url 추천: 시트 주소창의 주소를 그대로 복사)
[sheets]
spreadsheet_url = "https://docs.google.com/spreadsheets/d/시트ID/edit"
# spreadsheet_key = "시트ID"
# spreadsheet_name = "carrie-care"
